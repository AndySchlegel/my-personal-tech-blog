# Dependencies
node_modules/

# Build output
dist/
.next/

# Environment variables (NEVER commit secrets!)
.env
.env.*
!.env.example
*.tfvars
!*.tfvars.example

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
# NOTE: .terraform.lock.hcl is NOT ignored -- it pins exact provider versions
# for reproducible builds in CI. See: https://developer.hashicorp.com/terraform/language/files/dependency-lock

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/

# Docker
docker-compose.override.yml

# AI / Claude Code (local only)
CLAUDE.md
.claude/

# Feedback / drafts (local only, never commit)
feedback/

# Raw photos (originals too large for git, only optimized versions committed)
frontend/src/img/original-photo-*

# Screenshots (local reference only)
frontend/src/img/admin/Bildschirmfoto*
frontend/src/img/blog/Bildschirmfoto*
frontend/src/img/pipeline/Bildschirmfoto*

# Terraform plan files (binary, local only)
terraform/tfplan
terraform/tfplan-*
